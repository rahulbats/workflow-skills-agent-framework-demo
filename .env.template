# ---- Azure OpenAI ----
# Endpoint of your Azure OpenAI resource (no trailing slash needed)
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com
# Deployment name of the chat model (e.g. gpt-4o, gpt-4.1-mini)
AZURE_OPENAI_CHAT_MODEL=gpt-4o
# Optional: override API version (defaults to current Responses API version)
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- Azure Cosmos DB (NoSQL) ----
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE=insurance
COSMOS_CONTAINER=claims
# Optional for local Cosmos DB Emulator:
# COSMOS_ENDPOINT=https://localhost:8081/
# COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRB4O8CGn/KPZQ32QxQ=
# COSMOS_EMULATOR_DISABLE_SSL_VERIFY=true

# ---- Azure Blob Storage (object store for policy documents) ----
BLOB_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net
BLOB_CONTAINER=policies

# ---- Azure Event Grid (optional, for publishing final demo decisions) ----
# Topic endpoint URL, e.g. https://<topic-name>.<region>-1.eventgrid.azure.net/api/events
EVENT_GRID_TOPIC_ENDPOINT=
# Optional subject prefix used for published events
EVENT_GRID_SUBJECT_PREFIX=claims/decision
